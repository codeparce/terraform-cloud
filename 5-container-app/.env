TF_VAR_RESOURCE_GROUP_NAME=ca-$GITHUB_REF_NAME
TF_VAR_CONTAINER_APP_NAME=$GITHUB_REPOSITORY_NAME-$GITHUB_REF_NAME
TF_VAR_CONTAINER_IMAGE=$DOCKER_ACCOUNT_NAME/$GITHUB_REPOSITORY_NAME:$GITHUB_REF_NAME

TF_VAR_LOCATION=eastus

TF_VAR_CONTAINER_ENVIRONMENT=cae-$GITHUB_REF_NAME

TF_VAR_MAX_REPLICAS=1
TF_VAR_MIN_REPLICAS=0
TF_VAR_CPU=0.5
TF_VAR_MEMORY=1.0
TF_VAR_EXTERNAL_ENABLED=false